{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug STM32G473CBT6",
            "cwd": "${workspaceFolder}",
            "executable": "build/batterycasecontroller-debug/hardware/batterycasecontroller/unimoc.elf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "jlink",
            "device": "STM32G473CB",
            "breakAfterReset": true,
            "configFiles": [
                "modm/openocd.cfg",
            ],
            "rttConfig": {
                "enabled": true,
                "address": "auto",
                "decoders": [
                    {
                        "label": "",
                        "port": 0,
                        "type": "console"
                    },

                ]
            },
            "runToEntryPoint": "main",
            "preLaunchTask": "build batterycasecontroller-debug",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            }
        }
    ]
}